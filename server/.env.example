# Screen Recorder Server Configuration
# Copy this file to .env and update the values

# Server Settings
HOST=0.0.0.0
PORT=5000
DEBUG=false

# Security Settings (REQUIRED - Change these in production!)
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ADMIN_PASSWORD=your-secure-admin-password-min-12-chars

# Session Settings
SESSION_TIMEOUT=3600

# File Paths
UPLOAD_FOLDER=uploads
LICENSE_FOLDER=licenses
KEYS_FOLDER=keys
CLIENTS_FOLDER=clients

# Upload Settings
MAX_CONTENT_LENGTH=524288000
ALLOWED_EXTENSIONS=mp4,avi,mov,mkv

# Database Settings
DATABASE_URL=sqlite:///screenrecorder.db

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# HTTPS Settings (Optional - for production with SSL)
SSL_ENABLED=false
SSL_CERT=
SSL_KEY=
